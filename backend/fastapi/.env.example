# =============================================================================
# Symmetry Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=symmetry

# ── AI / LLM ────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434

# ── Event Streaming ─────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_TOPIC_RAW=raw_twitter_data
KAFKA_TOPIC_PROCESSED=processed_twitter_data

# ── Twitter API (only needed by twitter_worker) ─────────────────────────────
TWITTER_BEARER_TOKEN=

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ── Debug ────────────────────────────────────────────────────────────────────
DEBUG_MODE=false
