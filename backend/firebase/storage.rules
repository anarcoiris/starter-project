rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow public access to all article images for viewing
    match /users/{userId}/articles/{articleId} {
      allow read;
    }

    }
}