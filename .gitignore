# =============================================================================
# Symmetry Project — .gitignore
# =============================================================================

# ── Secrets & Environment ────────────────────────────────────────────────────
# Block ALL .env files everywhere, then whitelist .env.example templates
**/.env
**/.env.local
**/.env.*.local
.secret
mnemonic.txt
!**/.env.example

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.python-version
venv/
.venv/

# ── Node / Blockchain ───────────────────────────────────────────────────────
node_modules/
**/node_modules/
blockchain/artifacts/
blockchain/cache/
blockchain/typechain-types/
blockchain/coverage/
blockchain/coverage.json
blockchain/deployments/
blockchain/flatten/

# ── IDEs ─────────────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build & Testing ─────────────────────────────────────────────────────────
dist/
build/
out/
.pytest_cache/
.coverage
htmlcov/

# ── Generated / Ephemeral ───────────────────────────────────────────────────
backend/fastapi/exports/
**/scratch/
